# ============================================================
# MedCrypto — Environment Variables
# Copy file ini ke .env lalu isi nilainya
# JANGAN pernah commit .env ke Git!
# ============================================================

# Flask
FLASK_ENV=production
SECRET_KEY=ganti-dengan-random-string-panjang-minimal-32-char

# Master Key (KEK) — harus tepat 32 karakter atau lebih
MASTER_KEK=ganti-dengan-master-key-yang-sangat-rahasia-32c

# PostgreSQL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://medcrypto_user:password@localhost:5432/medcrypto_db

# Gunicorn (opsional, ada default)
GUNICORN_WORKERS=3
GUNICORN_PORT=8000
